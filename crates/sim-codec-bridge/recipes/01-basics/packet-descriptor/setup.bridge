BRIDGE/1
CID nil
MOVE request
FROM sim
TO [model:drafter]
ROLE implementer
PARENTS []
TASK T1
OUTPUT O1
CEIL [ai/run]
CONTEXT [C1]
PROV author=sim card=nil
BODY
FRAME T1 payload={"$expr":"map","entries":[{"key":{"$expr":"symbol","name":"frame"},"value":{"$expr":"symbol","namespace":"bridge","name":"produce-artifact"}}]}
RETURN O1 payload={"$expr":"map","entries":[{"key":{"$expr":"symbol","name":"codec"},"value":{"$expr":"symbol","namespace":"codec","name":"bridge"}}]}
END
